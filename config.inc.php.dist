<?php

// =============================================================================
// 배포 모드
// =============================================================================

// 브라우저가 WebDAV 요청을 보낼 기본 URL.
// 브라우저는 "<dav_base_url>/files/{user}/..." 및 "<dav_base_url>/uploads/{user}/..."에 PUT/MKCOL/MOVE를 수행합니다.
//
// Mode A (권장) — Roundcube nginx가 Nextcloud로 스트림 프록시:
//   "/nc-dav"
//
// Mode B/C — 브라우저가 Nextcloud에 직접 연결 (CORS 설정 필요):
//   "https://cloud.example.com/remote.php/dav"
//
// 끝에 슬래시 없음.
$config["nextcloud_direct_dav_base_url"] = "/nc-dav";

// 브라우저가 공유 링크 생성에 사용하는 OCS 기본 URL.
// Mode A: "/nc-ocs"   Mode B/C: "https://cloud.example.com/ocs"
// 끝에 슬래시 없음.
$config["nextcloud_direct_ocs_base_url"] = "/nc-ocs";

// Nextcloud의 서버 측 절대 URL. PHP에서 Device Flow 로그인,
// 앱 비밀번호 폐기, 로그인 확인에 사용합니다. 필수값.
// 예: "https://cloud.example.com" (내부 주소여도 무방)
$config["nextcloud_direct_server"] = "";

// 사용자에게 표시할 Nextcloud 공개 URL. 설정하면 설정 페이지에 링크로 표시됩니다.
// server가 내부 IP/주소일 때 사용. 비워두면 서버 주소 행이 숨겨집니다.
// 예: "https://drive.example.com"
$config["nextcloud_direct_public_url"] = "";

// =============================================================================
// 사용자 이름 해석
// =============================================================================

// Roundcube 사용자로부터 Nextcloud 사용자 이름을 구성하는 플레이스홀더.
// %s => RC 사용자명 그대로   %i => IMAP 로그인
// %e => 이메일   %l,%u => 로컬 파트   %d => 도메인   %h => IMAP 호스트
$config["nextcloud_direct_username"] = "%u";

// =============================================================================
// 업로드 동작
// =============================================================================

// 사용자 Nextcloud 내 업로드 대상 폴더. 하위 폴더는 지원하지 않습니다.
// 문자열 또는 로케일 키 배열로 지정 가능:
//   ["en_US" => "Mail Attachments", "ko_KR" => "메일 첨부파일"]
$config["nextcloud_direct_folder"] = "Mail Attachments";

// 청크 업로드 시 청크 크기 (MB). Nextcloud 기본값은 10입니다.
$config["nextcloud_direct_chunk_size_mb"] = 10;

// 이 크기(MB) 이하인 파일은 청크 업로드 대신 단일 PUT을 사용합니다.
$config["nextcloud_direct_single_put_threshold_mb"] = 10;

// 동시에 업로드할 청크 수. 값이 높을수록 빠르지만,
// Nextcloud PHP-FPM 워커 수가 적으면 503 오류가 발생할 수 있습니다. 4~8이 안전한 범위입니다.
$config["nextcloud_direct_chunk_concurrency"] = 4;

// 동시에 업로드할 파일 수. 여러 파일을 한꺼번에 선택했을 때 병렬로 처리합니다.
// 청크 동시성(chunk_concurrency)과 곱으로 작용하므로 값이 너무 크면
// Nextcloud PHP-FPM 워커 고갈로 503 오류가 발생할 수 있습니다.
// 권장: 1(순차, 기본값) ~ 3 정도.
$config["nextcloud_direct_file_concurrency"] = 1;

// 소프트 한도 (바이트 또는 "25M"). 이 크기를 초과하는 파일은 사용자에게 확인을 요청합니다.
// max_message_size보다 작아야 합니다. null로 설정하면 확인을 비활성화합니다.
$config["nextcloud_direct_softlimit"] = "25M";

// max_message_size를 초과했을 때의 동작:
//   "prompt" => 사용자에게 확인 요청 (Outlook/Apple 방식)
//   "upload" => 자동으로 파일 링크로 업로드 (Gmail 방식)
$config["nextcloud_direct_behavior"] = "prompt";

// =============================================================================
// 공유 링크 옵션
// =============================================================================

// 비밀번호로 보호된 링크를 생성합니다. 비밀번호는 메일 본문에만 표시됩니다.
$config["nextcloud_direct_password_protected_links"] = false;
// true로 설정하면 사용자가 설정 페이지에서 이 옵션을 변경할 수 없습니다.
$config["nextcloud_direct_password_protected_links_locked"] = true;
$config["nextcloud_direct_password_length"] = 12;
$config["nextcloud_direct_password_alphabets"] = [
    "123456789",
    "ABCDEFGHJKLMNPQRSTUVWXYZ",
    "abcdefghijkmnopqrstuvwxyz",
];

// 링크 만료 활성화 여부. true이면 공유 링크에 만료일이 설정됩니다.
$config["nextcloud_direct_expire_links"] = false;
// 링크 만료 기간 (일 단위). expire_links가 true일 때 적용됩니다.
$config["nextcloud_direct_expire_links_after"] = 7;
// true로 설정하면 사용자가 설정 페이지에서 만료 옵션을 변경할 수 없습니다.
$config["nextcloud_direct_expire_links_locked"] = false;

// =============================================================================
// 보안 / 접근 제어
// =============================================================================

// 서버 측 Nextcloud 호출 시 HTTPS 인증서를 검증합니다.
$config["nextcloud_direct_verify_https"] = true;

// 플러그인에서 완전히 제외할 RC 사용자 이름 또는 이메일 목록.
$config["nextcloud_direct_exclude_users"] = [];

// nextcloud_attachments 플러그인과 동일한 주소록 필터.
// 자세한 설명은 해당 플러그인의 config.inc.php.dist를 참고하세요.
$config["nextcloud_direct_exclude_users_in_addr_books"] = [];
$config["nextcloud_direct_exclude_users_with_addr_book_value"] = [];
$config["nextcloud_direct_exclude_users_in_addr_book_group"] = [];

// vim: set syntax=php ts=4 sw=4:
